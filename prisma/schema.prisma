// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  username          String
  email             String    @unique
  passwordHash      String    @map("password_hash")
  subscriptionPlan  String    @map("subscription_plan")
  projects          Project[]
  
  createdAt         DateTime  @default(now()) @map("created_at")
}

model Project {
  id          String       @id @default(cuid())
  title       String
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  status      String       @default("draft")
  
  // Relasi ke User
  userId      String       @map("user_id")
  user        User         @relation(fields: [userId], references: [id])
  
  // Relasi 1:1 ke DesignState
  designState DesignState?
  
  // Relasi 1:N ke ExportLog
  exportLogs  ExportLog[]
}

model DesignState {
  // project_id di diagram Anda adalah PK sekaligus FK
  projectId       String        @id @map("project_id")
  project         Project       @relation(fields: [projectId], references: [id])
  
  bodySilhouette  String        @map("body_silhouette")
  sleeveType      String        @map("sleeve_type")
  necklineType    String        @map("neckline_type")
  pocketType      String        @map("pocket_type")
  primaryColor    String        @map("primary_color")
  
  // Relasi ke PatternAsset
  activePatternId String?       @map("active_pattern_id")
  activePattern   PatternAsset? @relation(fields: [activePatternId], references: [id])
}

model ExportLog {
  id          String   @id @default(cuid())
  format      String
  exportedAt  DateTime @default(now()) @map("exported_at")
  
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id])
}

model PatternAsset {
  id           String        @id @default(cuid())
  name         String
  type         String
  svgRef       String        @map("svg_ref")
  designStates DesignState[]
}